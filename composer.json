{
    "name": "detain/myadmin-vmware-vps",
    "type": "myadmin-plugin",
    "description": "MyAdmin VMware VPS provisioning plugin - integrates VMware hypervisor management with the MyAdmin billing and service platform",
    "keywords": [
        "vmware",
        "vps",
        "virtualization",
        "myadmin",
        "plugin",
        "provisioning"
    ],
    "license": "LGPL-2.1-only",
    "authors": [
        {
            "name": "Joe Huss",
            "homepage": "https://my.interserver.net/"
        }
    ],
    "config": {
        "bin-dir": "vendor/bin",
        "minimum-stability": "dev"
    },
    "require": {
        "php": ">=8.2",
        "ext-soap": "*",
        "symfony/event-dispatcher": "^5.0||^6.0||^7.0",
        "detain/myadmin-plugin-installer": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Detain\\MyAdminVmware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Detain\\MyAdminVmware\\Tests\\": "tests/"
        }
    }
}
